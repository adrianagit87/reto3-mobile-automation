{
  "name": "reto3-mobile-automation",
  "version": "1.0.0",
  "description": "Reto 3 — Automatización mobile cross-platform (Android local + iOS SauceLabs) con WebdriverIO + Appium + POM",
  "main": "index.js",
  "scripts": {
    "test:android": "wdio run ./config/wdio.android.conf.ts",
    "test:ios": "wdio run ./config/wdio.ios.saucelabs.conf.ts",
    "test:all": "npm run test:android && npm run test:ios",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run report:open",
    "appium:doctor": "appium driver doctor uiautomator2",
    "clean": "rm -rf allure-results allure-report screenshots logs"
  },
  "keywords": [
    "appium",
    "webdriverio",
    "mobile-testing",
    "android",
    "ios",
    "page-object-model",
    "saucelabs"
  ],
  "author": "Adriana Troche",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@wdio/allure-reporter": "^9.27.1",
    "@wdio/appium-service": "^9.27.1",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/sauce-service": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/types": "^9.27.1",
    "appium": "^2.19.0",
    "appium-uiautomator2-driver": "^3.10.0",
    "appium-xcuitest-driver": "^7.35.1",
    "dotenv": "^16.6.1",
    "expect-webdriverio": "^5.6.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webdriverio": "^9.27.1"
  }
}
